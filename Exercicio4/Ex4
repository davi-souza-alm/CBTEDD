// À partir de uma lista de nomes disponível em um arquivo TXT, 
// transforma-los em nomes no formato citação bibliográfica. Exemplo:
// José Antonio Santos Silva
// SILVA, José A. S.

#include <iostream>
#include <fstream>
#include <sstream>
#include <vector>
#include <cctype>

using namespace std;

string maiusculo(string s) {
    for (char &c : s) c = toupper(c);
    return s;
}

int main() {
    ifstream file("nomes.txt");
    string linha;

    while (getline(file, linha)) {
        stringstream ss(linha);
        vector<string> partes;
        string palavra;

        while (ss >> palavra) {
            partes.push_back(palavra);
        }

        if (partes.size() > 0) {
            string sobrenome = maiusculo(partes.back());
            partes.pop_back();

            cout << sobrenome << ", ";

            for (string p : partes) {
                cout << (char)toupper(p[0]) << ". ";
            }

            cout << endl;
        }
    }

    return 0;
}
